rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 🛡️ AUTHENTICATION HELPERS ---
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isAuthenticated() && getUserData().get('role', '') == 'admin';
    }

    function isTeacher() {
      return isAuthenticated() && getUserData().get('role', '') == 'teacher';
    }

    function isStudent() {
      return isAuthenticated() && getUserData().get('role', '') == 'student';
    }

    // 🛡️ SECURITY: Verify if a batch is assigned
    function isMember(batchId) {
      let bData = get(/databases/$(database)/documents/batches/$(batchId)).data;
      return isAdmin() || (isAuthenticated() && (request.auth.uid in bData.get('students', []) || request.auth.uid in bData.get('teachers', [])));
    }

    // --- 📂 COLLECTIONS ---

    // 1. USERS
    match /users/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isAdmin() || isTeacher());
      allow write: if isAdmin() || (isAuthenticated() && request.auth.uid == uid);
    }

    // 2. BATCHES (Root)
    match /batches/{batchId} {
      allow read: if isAuthenticated(); 
      allow update: if isAdmin() || isTeacher(); 
      allow write: if isAdmin();

      // Attendance Sub-collection
      match /attendance/{sessionId} {
        allow read: if isAuthenticated(); // Simplified for now to avoid complexity in member check
        allow write: if isTeacher() || isAdmin();
      }

      // Sub-collections (Notes, Assignments, etc.)
      match /{allSubcollections=**} {
        allow read: if isAuthenticated();
        allow write: if isTeacher() || isAdmin();
      }
    }

    // 3. 🎥 SESSIONS (Root - New Protocol)
    match /sessions/{sessionId} {
      allow read: if isAuthenticated();
      
      // Allow creation if teacher or admin
      allow create: if isTeacher() || isAdmin();
      
      // Allow update if owner or admin
      allow update: if isAdmin() || (isTeacher() && request.auth.uid == resource.data.teacherId);
      
      allow delete: if isAdmin();
      
      // Presence/Check-ins sub-collection
      match /presence/{uid} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
    }

    // 4. E-PAPER / SETTINGS
    match /epaper/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // 🛡️ GLOBAL DEFAULT
    match /{path=**} {
      allow read, write: if isAdmin();
    }
  }
}
