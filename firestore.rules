rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 🛡️ AUTHENTICATION HELPERS ---
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }

    function isTeacher() {
      return isAuthenticated() && getUserData().role == 'teacher';
    }

    function isStudent() {
      return isAuthenticated() && getUserData().role == 'student';
    }

    // 🛡️ SECURITY: Verify if a batch is actually assigned to the user profile
    function isBatchAssigned(batchId) {
      return isAuthenticated() && batchId in getUserData().assignedBatches;
    }

    function getBatch(batchId) {
      return get(/databases/$(database)/documents/batches/$(batchId)).data;
    }

    // 🛡️ SECURITY: Cross-verify UID exists in the batch document for dual-layer safety
    function isTeacherOf(batchId) {
      return isAdmin() || (isBatchAssigned(batchId) && request.auth.uid in getBatch(batchId).teachers);
    }

    function isStudentOf(batchId) {
      return isAdmin() || (isBatchAssigned(batchId) && request.auth.uid in getBatch(batchId).students);
    }

    function isMember(batchId) {
      return isTeacherOf(batchId) || isStudentOf(batchId);
    }

    // --- 📂 COLLECTIONS ---

    // 1. 👤 USERS COLLECTION
    match /users/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isAdmin());
      
      // Self-onboarding (first login)
      allow create: if isAuthenticated() && 
                    request.auth.uid == uid && 
                    !exists(/databases/$(database)/documents/users/$(uid)) &&
                    (request.resource.data.role == 'student' || request.resource.data.role == 'teacher') &&
                    request.resource.data.assignedBatches == [];
      
      // Update logic: Admin can do anything, User can update profile but not assignedBatches
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (request.auth.uid == uid && (
          // Allow self-onboarding role selection if not set
          (!('role' in resource.data) || resource.data.role == null) ||
          // Allow profile updates (ensure critical fields like assignedBatches don't change without Admin)
          (request.resource.data.assignedBatches == resource.data.assignedBatches && 
           request.resource.data.uid == resource.data.uid)
        ))
      );
      allow delete: if isAdmin();
    }

    // 2. 📚 BATCHES COLLECTION
    match /batches/{batchId} {
      allow read: if isMember(batchId) || isAdmin();
      allow write: if isAdmin();

      // 🎥 Sub-collection: Sessions
      match /sessions/{sessionId} {
        allow read: if isMember(batchId) || isAdmin();
        // Only assigned teachers can create/edit sessions
        allow create: if isTeacherOf(batchId) && request.resource.data.teacherId == request.auth.uid;
        allow update: if isTeacherOf(batchId) || isAdmin();
        allow delete: if isAdmin();

        // ⏱️ Sub-collection: Check-ins (Real-time attendance signal)
        match /checkins/{studentUid} {
          allow read: if isTeacherOf(batchId) || (isStudent() && request.auth.uid == studentUid) || isAdmin();
          allow create: if isStudent() && request.auth.uid == studentUid && isStudentOf(batchId);
          allow update: if false; // Check-ins are usually immutable (one-time signal)
          allow delete: if isAdmin();
        }
      }

      // 📝 Sub-collection: Attendance (History)
      match /attendance/{sessionId} {
        allow read: if isMember(batchId) || isAdmin();
        allow write: if isTeacherOf(batchId) || isAdmin();
      }

      // 🗒️ Sub-collection: Notes/Resources
      match /notes/{noteId} {
        allow read: if isMember(batchId) || isAdmin();
        allow create, update: if isTeacherOf(batchId) || isAdmin();
        allow delete: if isTeacherOf(batchId) || isAdmin();
      }

      // 📝 Sub-collection: Assignments
      match /assignments/{assignmentId} {
        allow read: if isMember(batchId) || isAdmin();
        allow write: if isTeacherOf(batchId) || isAdmin();

        // 📤 Sub-collection: Submissions
        match /submissions/{studentUid} {
          allow read: if isTeacherOf(batchId) || (isStudent() && request.auth.uid == studentUid) || isAdmin();
          allow create: if isStudent() && request.auth.uid == studentUid && isStudentOf(batchId);
          allow update: if (isStudent() && request.auth.uid == studentUid) || isTeacherOf(batchId) || isAdmin();
          allow delete: if isAdmin();
        }
      }
    }

    // 3. 📰 E-PAPER / SETTINGS (Custom paths)
    match /epaper/{document=**} {
      allow read: if isAuthenticated(); 
      allow write: if isAdmin();        
    }
    
    match /settings/{document=**} {
      allow read: if true;         
      allow write: if isAdmin();   
    }

    // 🛡️ GLOBAL DEFAULT: Deny everything else
    match /{path=**} {
      allow read, write: if isAdmin(); 
    }
  }
}
